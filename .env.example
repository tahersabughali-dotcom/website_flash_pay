# Flash Pay — environment variables (copy to .env.local)
# Never commit .env.local or real secrets.

# Public site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional public chat widget toggle
NEXT_PUBLIC_CHAT_ENABLED=true

# Supabase (public anon client — safe for browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role — SERVER ONLY, never expose to browser or client components
SUPABASE_SERVICE_ROLE_KEY=

# Admin allowed emails — SERVER ONLY (format: email:role,email:role)
# Never display values in the UI — settings show configured yes/no only
ADMIN_ALLOWED_EMAILS=

# --- Production lockdown (Step 31) ---
# Keep ALL preview flags false in production unless admin auth + RLS are fully ready.
# Hidden URL is not security. Do not enable admin without Auth + roles + RLS.

# Global admin preview override (dashboard hub) — keep false in production
NEXT_PUBLIC_ENABLE_ADMIN_PREVIEW=false

# Per-route admin preview overrides — keep false in production
NEXT_PUBLIC_ENABLE_CHAT_ADMIN_PREVIEW=false
NEXT_PUBLIC_ENABLE_REQUEST_ADMIN_PREVIEW=false
NEXT_PUBLIC_ENABLE_CONTENT_ADMIN_PREVIEW=false

# Server-only admin auth — requires Supabase + ADMIN_ALLOWED_EMAILS
ENABLE_ADMIN_AUTH=false

# AI chat replies — keep false until tested with guardrails; requires OPENAI_API_KEY server-side
NEXT_PUBLIC_ENABLE_CHAT_AI=false

# Supabase Realtime for chat — keep false until RLS is production-ready
NEXT_PUBLIC_ENABLE_LIVE_CHAT_REALTIME=false

# OpenAI — SERVER ONLY
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
